# Slack
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
# comma-separated channel IDs the connector is allowed to act in (leave empty to allow all channels the bot is in)
SLACK_ALLOWED_CHANNELS=

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Discourse — set to false to skip posting and dump summaries to kb-summaries.md instead
DISCOURSE_ENABLED=true
DISCOURSE_BASE_URL=https://kb.arbyte-solutions.com
DISCOURSE_API_KEY=...
DISCOURSE_API_USERNAME=system
DISCOURSE_CATEGORY_ID=5

# Local SQLite file storing the (channel, thread_ts) -> (topic_id, last_message_ts)
# mapping. Must live on a persistent volume in production, not ephemeral storage.
DB_PATH=./data/kb.db

PORT=3000
